{
  "info": {
    "name": "Nhom 07 - Sushi Restaurant API - Demo Scenario",
    "description": "Collection demo cho Sushi Restaurant Management API. Chay python seed.py va python run.py truoc khi import/chay collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "base_url", "value": "http://127.0.0.1:5000"},
    {"key": "admin_token", "value": ""},
    {"key": "staff_token", "value": ""},
    {"key": "cashier_token", "value": ""},
    {"key": "registered_user_id", "value": ""},
    {"key": "created_category_id", "value": ""},
    {"key": "created_menu_item_id", "value": ""},
    {"key": "created_table_id", "value": ""},
    {"key": "created_customer_id", "value": ""},
    {"key": "order_id", "value": ""}
  ],
  "item": [
    {
      "name": "00 - Public And Login",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/health"
          }
        },
        {
          "name": "Register Demo Staff",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register demo staff OK', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json.user && json.user.id) pm.collectionVariables.set('registered_user_id', json.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Nhân viên demo {{$timestamp}}\",\n  \"username\": \"demo_staff_{{$timestamp}}\",\n  \"password\": \"demo123\"\n}"
            },
            "url": "{{base_url}}/api/auth/register"
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin login OK', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('admin_token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{base_url}}/api/auth/login"
          }
        },
        {
          "name": "Login Staff",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Staff login OK', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('staff_token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"staff\",\n  \"password\": \"staff123\"\n}"
            },
            "url": "{{base_url}}/api/auth/login"
          }
        },
        {
          "name": "Login Cashier",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Cashier login OK', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('cashier_token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"cashier\",\n  \"password\": \"cashier123\"\n}"
            },
            "url": "{{base_url}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "01 - Admin Master Data",
      "item": [
        {
          "name": "Get Users",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/users"
          }
        },
        {
          "name": "Update Registered User Role",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"role\": \"staff\"\n}"},
            "url": "{{base_url}}/api/users/{{registered_user_id}}/role"
          }
        },
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {"type": "text/javascript", "exec": ["pm.test('Create category OK', function () { pm.response.to.have.status(201); });", "const json = pm.response.json();", "pm.collectionVariables.set('created_category_id', json.category.id);"]}
            }
          ],
          "request": {
            "method": "POST",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Set đặc biệt {{$timestamp}}\",\n  \"description\": \"Nhóm món set cao cấp dùng cho kịch bản Postman\"\n}"},
            "url": "{{base_url}}/api/categories"
          }
        },
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/categories"
          }
        },
        {
          "name": "Get Created Category Detail",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/categories/{{created_category_id}}"
          }
        },
        {
          "name": "Update Created Category",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"description\": \"Set sushi cao cấp, dữ liệu demo cho bài thuyết trình\"\n}"},
            "url": "{{base_url}}/api/categories/{{created_category_id}}"
          }
        },
        {
          "name": "Create Menu Item",
          "event": [
            {
              "listen": "test",
              "script": {"type": "text/javascript", "exec": ["pm.test('Create menu item OK', function () { pm.response.to.have.status(201); });", "const json = pm.response.json();", "pm.collectionVariables.set('created_menu_item_id', json.menu_item.id);"]}
            }
          ],
          "request": {
            "method": "POST",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Set Nigiri cá hồi {{$timestamp}}\",\n  \"description\": \"Set 6 miếng nigiri cá hồi, đơn vị tiền VND\",\n  \"price\": 180000,\n  \"category_id\": {{created_category_id}}\n}"},
            "url": "{{base_url}}/api/menu-items"
          }
        },
        {
          "name": "Get Menu Items Public",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/menu-items"
          }
        },
        {
          "name": "Get Created Menu Item Detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/menu-items/{{created_menu_item_id}}"
          }
        },
        {
          "name": "Update Created Menu Item",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"price\": 195000,\n  \"status\": \"con_mon\",\n  \"is_available\": true\n}"},
            "url": "{{base_url}}/api/menu-items/{{created_menu_item_id}}"
          }
        },
        {
          "name": "Create Table",
          "event": [
            {
              "listen": "test",
              "script": {"type": "text/javascript", "exec": ["pm.test('Create table OK', function () { pm.response.to.have.status(201); });", "const json = pm.response.json();", "pm.collectionVariables.set('created_table_id', json.table.id);"]}
            }
          ],
          "request": {
            "method": "POST",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"table_number\": \"VIP-{{$timestamp}}\",\n  \"seats\": 4,\n  \"status\": \"trong\"\n}"},
            "url": "{{base_url}}/api/tables"
          }
        },
        {
          "name": "Get Tables",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/tables"
          }
        },
        {
          "name": "Update Created Table",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"status\": \"da_dat\"\n}"},
            "url": "{{base_url}}/api/tables/{{created_table_id}}"
          }
        }
      ]
    },
    {
      "name": "02 - Staff Customer And Order",
      "item": [
        {
          "name": "Create Customer",
          "event": [
            {
              "listen": "test",
              "script": {"type": "text/javascript", "exec": ["pm.test('Create customer OK', function () { pm.response.to.have.status(201); });", "const json = pm.response.json();", "pm.collectionVariables.set('created_customer_id', json.customer.id);"]}
            }
          ],
          "request": {
            "method": "POST",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"full_name\": \"Nguyễn Minh Anh {{$timestamp}}\",\n  \"phone\": \"09{{$timestamp}}\",\n  \"customer_type\": \"thanh_vien\",\n  \"member_tier\": \"vang\",\n  \"birth_date\": \"1998-05-12\",\n  \"note\": \"Khách đặt bàn VIP, dùng dữ liệu demo Postman\"\n}"},
            "url": "{{base_url}}/api/customers"
          }
        },
        {
          "name": "Get Customers",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/customers"
          }
        },
        {
          "name": "Update Created Customer",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"note\": \"Khách thành viên hạng vàng, ưu tiên bàn VIP\"\n}"},
            "url": "{{base_url}}/api/customers/{{created_customer_id}}"
          }
        },
        {
          "name": "Create Order From Demo Data",
          "event": [
            {
              "listen": "test",
              "script": {"type": "text/javascript", "exec": ["pm.test('Create order OK', function () { pm.response.to.have.status(201); });", "const json = pm.response.json();", "pm.collectionVariables.set('order_id', json.order.id);"]}
            }
          ],
          "request": {
            "method": "POST",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"table_id\": {{created_table_id}},\n  \"customer_id\": {{created_customer_id}},\n  \"items\": [\n    {\"menu_item_id\": {{created_menu_item_id}}, \"quantity\": 2}\n  ]\n}"},
            "url": "{{base_url}}/api/orders"
          }
        },
        {
          "name": "Get Orders",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/orders"
          }
        },
        {
          "name": "Get Created Order Detail",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/orders/{{order_id}}"
          }
        },
        {
          "name": "Update Order Status To Served",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"status\": \"da_phuc_vu\"\n}"},
            "url": "{{base_url}}/api/orders/{{order_id}}/status"
          }
        }
      ]
    },
    {
      "name": "03 - Cashier Payment And Invoice",
      "item": [
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{cashier_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"order_id\": {{order_id}},\n  \"payment_method\": \"tien_mat\"\n}"},
            "url": "{{base_url}}/api/payments"
          }
        },
        {
          "name": "Get Payments",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{cashier_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/payments"
          }
        },
        {
          "name": "Get Invoice",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{cashier_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/invoices/{{order_id}}"
          }
        }
      ]
    },
    {
      "name": "04 - Admin Reports And Auth Guards",
      "item": [
        {
          "name": "Statistics Overview",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/statistics"
          }
        },
        {
          "name": "Revenue",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/statistics/revenue"
          }
        },
        {
          "name": "Popular Items",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/statistics/popular-items?top=5"
          }
        },
        {
          "name": "Revenue By Day",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/statistics/by-day"
          }
        },
        {
          "name": "Revenue By Staff",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/statistics/by-staff"
          }
        },
        {
          "name": "Guard - Missing Token Should Be 401",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/users"
          }
        },
        {
          "name": "Guard - Staff Access Users Should Be 403",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/users"
          }
        }
      ]
    },
    {
      "name": "05 - Cleanup",
      "item": [
        {
          "name": "Delete Created Menu Item",
          "request": {
            "method": "DELETE",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/menu-items/{{created_menu_item_id}}"
          }
        },
        {
          "name": "Release Created Table",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"status\": \"trong\"\n}"},
            "url": "{{base_url}}/api/tables/{{created_table_id}}"
          }
        },
        {
          "name": "Logout Admin",
          "request": {
            "method": "POST",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/auth/logout"
          }
        },
        {
          "name": "Logout Cashier",
          "request": {
            "method": "POST",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{cashier_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/auth/logout"
          }
        }
      ]
    }
  ]
}
