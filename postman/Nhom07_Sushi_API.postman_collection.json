{
  "info": {
    "name": "Nhom 07 - Sushi Restaurant API - 36 Endpoints",
    "description": "Postman collection khop voi source hien tai: 36 endpoint Flask REST API. Chay python seed.py va python run.py truoc khi test.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "base_url", "value": "http://127.0.0.1:5000"},
    {"key": "admin_token", "value": ""},
    {"key": "staff_token", "value": ""},
    {"key": "cashier_token", "value": ""},
    {"key": "category_id", "value": "1"},
    {"key": "menu_item_id", "value": "1"},
    {"key": "table_id", "value": "1"},
    {"key": "customer_id", "value": "1"},
    {"key": "order_id", "value": "1"},
    {"key": "user_id", "value": "1"}
  ],
  "item": [
    {
      "name": "00 - Public And Auth",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/health"
          }
        },
        {
          "name": "Register Staff",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Demo Staff\",\n  \"username\": \"demo_staff\",\n  \"password\": \"demo123\"\n}"
            },
            "url": "{{base_url}}/api/auth/register"
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('admin_token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{base_url}}/api/auth/login"
          }
        },
        {
          "name": "Login Staff",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('staff_token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"staff\",\n  \"password\": \"staff123\"\n}"
            },
            "url": "{{base_url}}/api/auth/login"
          }
        },
        {
          "name": "Login Cashier",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('cashier_token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"cashier\",\n  \"password\": \"cashier123\"\n}"
            },
            "url": "{{base_url}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "01 - Admin",
      "item": [
        {
          "name": "Get Users",
          "request": {
            "method": "GET",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/users"
          }
        },
        {
          "name": "Update User Role",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"role\": \"staff\"\n}"},
            "url": "{{base_url}}/api/users/{{user_id}}/role"
          }
        },
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {"type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.category) pm.collectionVariables.set('category_id', json.category.id);"]}
            }
          ],
          "request": {
            "method": "POST",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Demo Category\",\n  \"description\": \"Created from Postman\"\n}"},
            "url": "{{base_url}}/api/categories"
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"description\": \"Updated from Postman\"\n}"},
            "url": "{{base_url}}/api/categories/{{category_id}}"
          }
        },
        {
          "name": "Create Menu Item",
          "event": [
            {
              "listen": "test",
              "script": {"type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.menu_item) pm.collectionVariables.set('menu_item_id', json.menu_item.id);"]}
            }
          ],
          "request": {
            "method": "POST",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Demo Nigiri\",\n  \"description\": \"Created from Postman\",\n  \"price\": 42000,\n  \"category_id\": {{category_id}}\n}"},
            "url": "{{base_url}}/api/menu-items"
          }
        },
        {
          "name": "Update Menu Item",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"price\": 50000,\n  \"status\": \"con_mon\",\n  \"is_available\": true\n}"},
            "url": "{{base_url}}/api/menu-items/{{menu_item_id}}"
          }
        },
        {
          "name": "Create Table",
          "event": [
            {
              "listen": "test",
              "script": {"type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.table) pm.collectionVariables.set('table_id', json.table.id);"]}
            }
          ],
          "request": {
            "method": "POST",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"table_number\": \"P20\",\n  \"seats\": 4,\n  \"status\": \"trong\"\n}"},
            "url": "{{base_url}}/api/tables"
          }
        },
        {
          "name": "Delete Menu Item",
          "request": {
            "method": "DELETE",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/menu-items/{{menu_item_id}}"
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/categories/{{category_id}}"
          }
        }
      ]
    },
    {
      "name": "02 - Catalog And People",
      "item": [
        {"name": "Get Categories", "request": {"method": "GET", "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]}, "url": "{{base_url}}/api/categories"}},
        {"name": "Get Category Detail", "request": {"method": "GET", "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]}, "url": "{{base_url}}/api/categories/{{category_id}}"}},
        {"name": "Get Menu Items", "request": {"method": "GET", "url": "{{base_url}}/api/menu-items"}},
        {"name": "Get Menu Item Detail", "request": {"method": "GET", "url": "{{base_url}}/api/menu-items/{{menu_item_id}}"}},
        {"name": "Get Tables", "request": {"method": "GET", "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]}, "url": "{{base_url}}/api/tables"}},
        {
          "name": "Update Table",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"status\": \"trong\"\n}"},
            "url": "{{base_url}}/api/tables/{{table_id}}"
          }
        },
        {"name": "Get Customers", "request": {"method": "GET", "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]}, "url": "{{base_url}}/api/customers"}},
        {
          "name": "Create Customer",
          "event": [
            {
              "listen": "test",
              "script": {"type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.customer) pm.collectionVariables.set('customer_id', json.customer.id);"]}
            }
          ],
          "request": {
            "method": "POST",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"full_name\": \"Demo Customer\",\n  \"phone\": \"0900000020\",\n  \"note\": \"Created from Postman\"\n}"},
            "url": "{{base_url}}/api/customers"
          }
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"note\": \"Updated from Postman\"\n}"},
            "url": "{{base_url}}/api/customers/{{customer_id}}"
          }
        },
        {
          "name": "Delete Customer",
          "request": {
            "method": "DELETE",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/customers/{{customer_id}}"
          }
        },
        {
          "name": "Delete Table",
          "request": {
            "method": "DELETE",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]},
            "url": "{{base_url}}/api/tables/{{table_id}}"
          }
        }
      ]
    },
    {
      "name": "03 - Order Payment Invoice",
      "item": [
        {"name": "Get Orders", "request": {"method": "GET", "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]}, "url": "{{base_url}}/api/orders"}},
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {"type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.order) pm.collectionVariables.set('order_id', json.order.id);"]}
            }
          ],
          "request": {
            "method": "POST",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"table_id\": 1,\n  \"customer_id\": 1,\n  \"items\": [\n    {\"menu_item_id\": 1, \"quantity\": 2}\n  ]\n}"},
            "url": "{{base_url}}/api/orders"
          }
        },
        {"name": "Get Order Detail", "request": {"method": "GET", "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]}, "url": "{{base_url}}/api/orders/{{order_id}}"}},
        {
          "name": "Update Order Status",
          "request": {
            "method": "PUT",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{staff_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"status\": \"da_phuc_vu\"\n}"},
            "url": "{{base_url}}/api/orders/{{order_id}}/status"
          }
        },
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{cashier_token}}", "type": "string"}]},
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"order_id\": {{order_id}},\n  \"payment_method\": \"tien_mat\"\n}"},
            "url": "{{base_url}}/api/payments"
          }
        },
        {"name": "Get Payments", "request": {"method": "GET", "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{cashier_token}}", "type": "string"}]}, "url": "{{base_url}}/api/payments"}},
        {"name": "Get Invoice", "request": {"method": "GET", "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{cashier_token}}", "type": "string"}]}, "url": "{{base_url}}/api/invoices/{{order_id}}"}}
      ]
    },
    {
      "name": "04 - Statistics",
      "item": [
        {"name": "Overview", "request": {"method": "GET", "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]}, "url": "{{base_url}}/api/statistics"}},
        {"name": "Revenue", "request": {"method": "GET", "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]}, "url": "{{base_url}}/api/statistics/revenue"}},
        {"name": "Popular Items", "request": {"method": "GET", "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]}, "url": "{{base_url}}/api/statistics/popular-items?top=5"}},
        {"name": "Revenue By Day", "request": {"method": "GET", "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]}, "url": "{{base_url}}/api/statistics/by-day"}},
        {"name": "Revenue By Staff", "request": {"method": "GET", "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{admin_token}}", "type": "string"}]}, "url": "{{base_url}}/api/statistics/by-staff"}}
      ]
    }
  ]
}
